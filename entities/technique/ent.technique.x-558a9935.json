  "attributes": {
    "出处": "黑煞教、魔道、玄骨老魔遗物玉简、玄阴经玉简、玄阴岛/玄阴一脉、玄骨老魔肋骨玉简",
    "五行属性": "阴",
    "效果": "魔道功法总纲、霸道异常、威力强；下半部含天都尸火等秘术、记载阴火雷雷珠炼制法、阴魔斩等、记载离魂术等阴属秘法、霸道威力强、下半部含天都尸火等秘术、收录多种易容隐匿秘术",
    "品阶": "魔道功法、高阶功法、魔道高阶功法",
    "修炼条件": "部分秘术须元婴期以上、以玄阴经为基础",
    "适用境界": "结丹"
  },
